BOT_TOKEN=123456:ABC-DEF...
# Необязательно: если задан — обычные сообщения (без чужой ссылки) дублируются админу
ADMIN_USER_ID=123456789
# Поддержка (без @): кнопка «Пожаловаться» у получателя анонима и ссылки в /start
SUPPORT_USERNAME=quesupport
# Необязательно: custom_emoji_id для кастомного эмодзи в заголовке «У тебя новое сообщение!»
# (HTML-тег tg-emoji; внутри — запасной символ 💬 для уведомлений без анимации).
# Условия Bot API: кастомные эмодзи в исходящих сообщениях бота допустимы, если у владельца бота
# есть Telegram Premium ИЛИ у бота куплено дополнительное имя на Fragment. Иначе Telegram вернёт ошибку.
# Как узнать emoji-id: отправьте себе нужное эмодзи (например из набора News), перешлите боту-отладчику
# или прочитайте update.message.entities у сообщения с type=custom_emoji (поле custom_emoji_id).
# ANON_NEW_MESSAGE_CUSTOM_EMOJI_ID=12345678901234567890
